{
  "nodeModulesDir": "auto",
  "tasks": {
    "server:watch": "deno run -A --env-file --watch=./views main.ts",
    "db:push": "deno run -A --env-file npm:prisma db push",
    "db:generate": "deno run -A --env-file npm:prisma generate"
  },
  "imports": {
    "#/": "./",
    "@prisma/adapter-better-sqlite3": "npm:@prisma/adapter-better-sqlite3@^7.5.0",
    "@prisma/client": "npm:@prisma/client@^7.5.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "eta": "npm:eta@^4.5.1",
    "express": "npm:express@^5.2.1",
    "prisma": "npm:prisma@^7.5.0"
  },
  "allowScripts": [
    "npm:@prisma/engines@7.5.0",
    "npm:better-sqlite3@12.8.0",
    "npm:prisma@7.5.0"
  ]
}
