{
  "name": "smartphone-garden",
  "private": true,
  "type": "module",
  "scripts": {
    "server": "tsx --env-file=./.env ./app.ts",
    "server:watch": "tsx watch --env-file=./.env --include ./views ./app.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "build": "tsx ./build.ts",
    "build:watch": "tsx ./build.ts --watch",
    "dev": "concurrently -c \"#93c5fd,#c4b5fd\" \"pnpm server:watch\" \"pnpm build:watch\" --names=express,esbuild"
  },
  "devDependencies": {
    "@types/bootstrap": "^5.2.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.8",
    "prisma": "^7.6.0",
    "sass-embedded": "^1.98.0",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bootstrap": "5.3.8",
    "dotenv": "^17.3.1",
    "eta": "^4.5.1",
    "express": "^5.2.1",
    "htmx.org": "2.0.8",
    "remixicon": "^4.9.1"
  }
}
